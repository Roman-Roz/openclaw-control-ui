{
  "name": "openclaw-control-ui",
  "version": "2.0.0",
  "description": "OpenClaw Control UI - Cyberpunk Control Panel for Vercel Deployment",
  "main": "src/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "concurrently \"tsc --watch\" \"nodemon dist/server.js\"",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "openclaw",
    "cyberpunk",
    "control-panel",
    "dashboard",
    "ai",
    "gateway",
    "neon",
    "ui"
  ],
  "author": "OpenClaw Community",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.3",
    "qrcode": "^1.5.4",
    "redis": "^5.12.1",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "systeminformation": "^5.31.5",
    "uuid": "^8.3.2",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.45.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "morgan": "^1.10.1",
    "node-fetch": "^3.3.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openclaw/openclaw-cyberpunk-panel.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw-cyberpunk-panel/issues"
  },
  "homepage": "https://github.com/openclaw/openclaw-cyberpunk-panel#readme"
}
